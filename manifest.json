{
  "manifest_version": 3,
  "name": "AlgoNotion",
  "short_name": "AlgoNotion",
  "description": "알고노션은 백준·SWEA·프로그래머스 정답 제출을 Notion 데이터베이스에 자동으로 저장합니다. Automatically sync your solved algorithm problems to Notion.",
  "version": "2.5.0",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://www.acmicpc.net/*",
    "https://solved.ac/*",
    "https://swexpertacademy.com/*",
    "https://school.programmers.co.kr/*",
    "https://algonotion.site/*",
    "https://api.notion.com/*",
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.acmicpc.net/status*",
        "https://www.acmicpc.net/submit/*"
      ],
      "js": [
        "content/baekjoon_content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://swexpertacademy.com/*"
      ],
      "js": [
        "content/swea_content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://school.programmers.co.kr/learn/*"
      ],
      "js": [
        "content/programmers_content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://school.programmers.co.kr/learn/*"
      ],
      "js": [
        "content/programmers_monaco_bridge.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html"
}

